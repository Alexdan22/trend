# Independent AI Market Analyst. Safe default: fully disabled.
AI_ANALYST_MODE=OFF
AI_ANALYST_MODEL=gpt-5.4-mini
AI_ANALYST_SIGNALS_ENABLED=false
AI_ANALYST_CONTROLS_ENABLED=false
AI_ANALYST_EXITS_ENABLED=false
AI_ANALYST_TELEGRAM_ENABLED=false
AI_ANALYST_REASONING_EFFORT=low
AI_ANALYST_TIMEOUT_MS=30000
AI_ANALYST_CONTROL_INTERVAL_MINUTES=30
AI_ANALYST_CONTROL_DEDUP_MINUTES=10
AI_ANALYST_MAX_RPM=4
AI_ANALYST_MAX_CALLS_PER_DAY=60
AI_ANALYST_MAX_DAILY_COST_USD=1.00
AI_ANALYST_MAX_QUEUE=100
AI_ANALYST_M1_CANDLES=120
AI_ANALYST_M5_CANDLES=96
AI_ANALYST_M30_CANDLES=100
AI_ANALYST_IMAGE_DETAIL=high

# Required only when AI_ANALYST_MODE=OBSERVE. Install out-of-band; never commit it.
OPENAI_API_KEY=
